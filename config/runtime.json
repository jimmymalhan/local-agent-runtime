{
  "backend": "ollama",
  "base_url": "http://127.0.0.1:11434",
  "default_model": "qwen2.5-coder:7b",
  "providers": {
    "ollama": {
      "kind": "ollama",
      "base_url": "http://127.0.0.1:11434"
    },
    "github_models": {
      "kind": "github_models",
      "base_url": "https://models.github.ai/inference/chat/completions",
      "token_env": "GITHUB_MODELS_TOKEN",
      "enabled_env": "LOCAL_AGENT_ENABLE_GITHUB_MODELS",
      "api_version": "2022-11-28",
      "default_model": "openai/gpt-4.1-mini",
      "role_models": {
        "planner": "openai/gpt-4.1",
        "reviewer": "openai/gpt-4.1",
        "benchmarker": "openai/gpt-4.1",
        "qa": "openai/gpt-4.1",
        "summarizer": "openai/gpt-4.1",
        "architect": "openai/gpt-4.1-mini",
        "implementer": "openai/gpt-4.1-mini",
        "tester": "openai/gpt-4.1-mini",
        "debugger": "openai/gpt-4.1-mini"
      }
    },
    "clawbot": {
      "kind": "openai_compatible",
      "base_url_env": "CLAWBOT_BASE_URL",
      "token_env": "CLAWBOT_API_KEY",
      "enabled_env": "LOCAL_AGENT_ENABLE_CLAWBOT",
      "chat_path": "/v1/chat/completions",
      "default_model_env": "CLAWBOT_MODEL",
      "default_model": "clawbot/default"
    },
    "openclaw": {
      "kind": "openai_compatible",
      "base_url_env": "OPENCLAW_BASE_URL",
      "token_env": "OPENCLAW_GATEWAY_TOKEN",
      "fallback_token_env": "OPENCLAW_GATEWAY_PASSWORD",
      "enabled_env": "LOCAL_AGENT_ENABLE_OPENCLAW",
      "chat_path": "/v1/chat/completions",
      "default_model_env": "OPENCLAW_MODEL",
      "default_model": "openclaw/default",
      "models": {
        "reasoning_env": "OPENCLAW_REASONING_MODEL",
        "coding_env": "OPENCLAW_CODING_MODEL",
        "fast_env": "OPENCLAW_FAST_MODEL"
      }
    }
  },
  "default_profile": "fast",
  "team_order": [
    "researcher",
    "retriever",
    "planner",
    "architect",
    "implementer",
    "tester",
    "reviewer",
    "debugger",
    "optimizer",
    "benchmarker",
    "qa",
    "user_acceptance",
    "summarizer"
  ],
  "prompt_budget": {
    "project_context_chars": 160000,
    "rag_context_chars": 20000,
    "tool_registry_chars": 30000,
    "history_chars": 40000,
    "prior_output_chars": 80000,
    "mentioned_files_chars": 30000,
    "latest_response_chars": 12000,
    "review_report_chars": 12000,
    "qa_report_chars": 15000,
    "session_summary_chars": 8000,
    "common_plan_chars": 20000
  },
  "prompt_budget_exhaustive": {
    "project_context_chars": 600000,
    "rag_context_chars": 60000,
    "tool_registry_chars": 60000,
    "history_chars": 120000,
    "prior_output_chars": 180000,
    "mentioned_files_chars": 80000,
    "latest_response_chars": 30000,
    "review_report_chars": 25000,
    "qa_report_chars": 30000,
    "session_summary_chars": 15000,
    "common_plan_chars": 60000
  },
  "num_ctx": 32768,
  "lock_wait_seconds": 15,
  "profiles": {
    "fast": {
      "description": "Lowest-cost local profile: shared plan first, then only the highest-ROI roles for quick answers and light changes.",
      "team_order": [
        "researcher",
        "retriever",
        "planner",
        "implementer",
        "summarizer"
      ],
      "group_order": [
        [
          "researcher",
          "retriever"
        ],
        [
          "planner"
        ],
        [
          "implementer"
        ],
        [
          "summarizer"
        ]
      ],
      "max_parallel_roles": 2,
      "num_ctx": 8192,
      "temperature": 0.1,
      "retry_generic_output": 1,
      "lock_wait_seconds": 8,
      "resource_limits": {
        "poll_seconds": 1,
        "takeover_wait_seconds": 8,
        "max_resource_wait_events": 3,
        "parallel_headroom_cpu_percent": 65,
        "parallel_headroom_memory_percent": 65,
        "model_downgrade_cpu_percent": 55,
        "model_downgrade_memory_percent": 55
      }
    },
    "balanced": {
      "description": "ROI-balanced local team: full build path, but with lighter critique and fewer low-yield side roles under the 70 percent machine budget.",
      "team_order": [
        "researcher",
        "retriever",
        "planner",
        "architect",
        "implementer",
        "tester",
        "reviewer",
        "debugger",
        "qa",
        "summarizer"
      ],
      "group_order": [
        [
          "researcher",
          "retriever"
        ],
        [
          "planner"
        ],
        [
          "architect",
          "implementer"
        ],
        [
          "tester",
          "reviewer",
          "debugger"
        ],
        [
          "qa"
        ],
        [
          "summarizer"
        ]
      ],
      "max_parallel_roles": 2,
      "num_ctx": 24576,
      "temperature": 0.15,
      "retry_generic_output": 1
    },
    "deep": {
      "description": "Higher-quality ROI path: keep the strong critique loop, but reserve expensive depth for roles that materially change output quality.",
      "team_order": [
        "researcher",
        "retriever",
        "planner",
        "architect",
        "implementer",
        "tester",
        "reviewer",
        "debugger",
        "optimizer",
        "benchmarker",
        "qa",
        "summarizer"
      ],
      "group_order": [
        [
          "researcher",
          "retriever"
        ],
        [
          "planner"
        ],
        [
          "architect",
          "implementer"
        ],
        [
          "tester",
          "reviewer",
          "debugger"
        ],
        [
          "optimizer",
          "benchmarker",
          "qa"
        ],
        [
          "summarizer"
        ]
      ],
      "max_parallel_roles": 2,
      "num_ctx": 28672,
      "temperature": 0.1,
      "retry_generic_output": 2
    },
    "exhaustive": {
      "description": "Most detailed local mode: larger prompt budgets, common-plan-first execution, and coordinated critique while staying within 70 percent CPU and memory.",
      "team_order": [
        "researcher",
        "retriever",
        "planner",
        "architect",
        "implementer",
        "tester",
        "reviewer",
        "debugger",
        "optimizer",
        "benchmarker",
        "qa",
        "user_acceptance",
        "summarizer"
      ],
      "group_order": [
        [
          "researcher",
          "retriever"
        ],
        [
          "planner"
        ],
        [
          "architect",
          "implementer"
        ],
        [
          "tester",
          "reviewer",
          "debugger"
        ],
        [
          "optimizer",
          "benchmarker"
        ],
        [
          "qa",
          "user_acceptance"
        ],
        [
          "summarizer"
        ]
      ],
      "max_parallel_roles": 2,
      "num_ctx": 49152,
      "temperature": 0.05,
      "retry_generic_output": 4,
      "resource_limits": {
        "cpu_percent": 70,
        "memory_percent": 70,
        "ollama_num_parallel": 3,
        "ollama_max_loaded_models": 3,
        "ollama_keep_alive": "10m"
      },
      "use_exhaustive_budget": true
    }
  },
  "quality": {
    "min_response_chars": 320,
    "generic_phrases": [
      "i do not have access",
      "i don't have access",
      "not enough context",
      "more context would help",
      "based on the information provided",
      "it appears that",
      "it seems that",
      "without additional details"
    ],
    "concrete_term_markers": [
      "/",
      ".py",
      ".sh",
      ".md",
      "git ",
      "python3 ",
      "bash "
    ]
  },
  "roi": {
    "kill_switch_enabled": true,
    "negative_trend_window": 6,
    "negative_trend_threshold": 3,
    "max_event_age_minutes": 15
  },
  "team": {
    "researcher": {
      "model": "qwen2.5:3b",
      "fallback_models": [
        "llama3.2:3b"
