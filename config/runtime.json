  "personalities": {
    "friendly": "Respond in a warm, conversational way. Use plain language and occasional encouragement.",
    "pragmatic": "Be direct, terse, and action-focused. Skip pleasantries; prioritize concrete steps.",
    "none": "Respond neutrally without personality instructions."
  },
  "resource_limits": {
